    /* Botones de abajo (GUARDAR CAMBIOS y CUENTAS DE EMPLEADOS) */
    .btn-igual {
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 12px;
        font-weight: 600;
        font-size: 0.9rem;
