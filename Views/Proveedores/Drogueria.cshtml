@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const idProveedor = @((ViewData["IdProveedor"] ?? 1));
        const nombreProveedorServer = @Html.Raw(Json.Serialize(ViewData["NombreProveedor"] ?? "Proveedor"));
        const idUsuario = parseInt('@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")', 10);
        const STORAGE_KEY = `boletas_${idProveedor}`;

        // ====================== STORAGE ======================
        function guardarTablasEnStorage() {
            const datos = { perfumeria: [], medicamentos: [] };

            document.querySelectorAll('#tablaPerfumeria tbody tr').forEach(tr => {
                const celdas = tr.querySelectorAll('td');
                const boletaId = tr.getAttribute("data-boleta-id");
                if (celdas.length >= 3) {
                    datos.perfumeria.push({
                        id: boletaId || null,
                        fecha: celdas[0].innerText.trim(),
                        importe: celdas[1].innerText.trim(),
                        transfer: celdas[2].innerText.trim()
                    });
                }
            });

            document.querySelectorAll('#tablaMedicamentos tbody tr').forEach(tr => {
                const celdas = tr.querySelectorAll('td');
                const boletaId = tr.getAttribute("data-boleta-id");
                if (celdas.length >= 3) {
                    datos.medicamentos.push({
                        id: boletaId || null,
                        fecha: celdas[0].innerText.trim(),
                        importe: celdas[1].innerText.trim(),
                        transfer: celdas[2].innerText.trim()
                    });
                }
            });

            localStorage.setItem(STORAGE_KEY, JSON.stringify(datos));
        }

        function cargarTablasDesdeStorage() {
            const datosGuardados = localStorage.getItem(STORAGE_KEY);
            if (!datosGuardados) return;
            try {
                const datos = JSON.parse(datosGuardados);

                document.querySelector('#tablaPerfumeria tbody').innerHTML = '';
                document.querySelector('#tablaMedicamentos tbody').innerHTML = '';

                datos.perfumeria.forEach(item => {
                    const tr = document.createElement('tr');
                    if (item.id) tr.setAttribute("data-boleta-id", item.id);
                    tr.innerHTML = `<td>${item.fecha}</td><td>${item.importe}</td><td>${item.transfer}</td>
                                    <td class="text-center"><input type="checkbox" class="fila-check"></td>`;
                    document.querySelector('#tablaPerfumeria tbody').appendChild(tr);
                });

                datos.medicamentos.forEach(item => {
                    const tr = document.createElement('tr');
                    if (item.id) tr.setAttribute("data-boleta-id", item.id);
                    tr.innerHTML = `<td>${item.fecha}</td><td>${item.importe}</td><td>${item.transfer}</td>
                                    <td class="text-center"><input type="checkbox" class="fila-check"></td>`;
                    document.querySelector('#tablaMedicamentos tbody').appendChild(tr);
                });
            } catch (e) {
                console.error("Error al cargar desde storage:", e);
            }
        }

        // ====================== CARGAR BOLETAS REALES DESDE BD (NUEVO) ======================
        async function cargarBoletasDesdeBD() {
            try {
                const res = await fetch(`/Boleta/GetBoletas?idProveedor=${idProveedor}`);
                const data = await res.json();

                if (!data.success || !data.data) {
                    console.warn("No se pudieron cargar boletas desde BD");
                    return;
                }

                // Limpiar tablas antes de cargar desde BD
                document.querySelector('#tablaPerfumeria tbody').innerHTML = '';
                document.querySelector('#tablaMedicamentos tbody').innerHTML = '';

                data.data.forEach(boleta => {
                    const categoria = boleta.categoria?.toLowerCase() || "";
                    const idTabla = categoria.includes("perfumer") ? "tablaPerfumeria" : "tablaMedicamentos";
                    const tbody = document.querySelector(`#${idTabla} tbody`);

                    const tr = document.createElement("tr");
                    tr.setAttribute("data-boleta-id", boleta.idboleta);
                    tr.innerHTML = `
                        <td>${boleta.fecha}</td>
                        <td>$${Number(boleta.importeFinal).toLocaleString('es-AR')}</td>
                        <td>${boleta.transfer || 'No'}</td>
                        <td class="text-center"><input type="checkbox" class="fila-check"></td>
                    `;
                    tbody.appendChild(tr);
                });

                // Actualizar localStorage con los datos correctos (incluyendo IDs)
                guardarTablasEnStorage();

                console.log("[BD] Boletas cargadas correctamente desde la base de datos");
            } catch (err) {
                console.error("[BD] Error al cargar boletas desde BD:", err);
            }
        }

        function limpiarImporte(importe) {
            return parseInt((importe || "").toString().replace(/\./g, ""), 10) || 0;
        }

        function formatoFechaInputAmostrar(dateValue) {
            if (!dateValue) return new Date().toLocaleDateString();
            const parts = dateValue.split("-");
            return parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : dateValue;
        }

        function crearFilasVacias(idTabla, cantidad = 5) {
            const tbody = document.querySelector(`#${idTabla} tbody`);
            if (!tbody) return;
            tbody.innerHTML = "";
            for (let i = 0; i < cantidad; i++) {
                const fila = document.createElement("tr");
                fila.innerHTML = `<td></td><td></td><td></td><td class="text-center"><input type="checkbox" class="fila-check"></td>`;
                tbody.appendChild(fila);
            }
        }

        // ====================== QUITAR OUTLINE AZUL ======================
        const style = document.createElement('style');
        style.innerHTML = `button, .btn { outline: none !important; box-shadow: none !important; }`;
        document.head.appendChild(style);

        // ====================== INICIALIZACIÓN ======================
        document.addEventListener("DOMContentLoaded", function () {
            // Primero intenta cargar desde localStorage (por si hay datos temporales)
            cargarTablasDesdeStorage();

            // Luego carga desde BD (esto sobreescribe y asegura IDs correctos)
            cargarBoletasDesdeBD();

            // Si alguna tabla quedó vacía después de cargar desde BD
            if (document.querySelectorAll('#tablaPerfumeria tbody tr').length === 0) crearFilasVacias("tablaPerfumeria");
            if (document.querySelectorAll('#tablaMedicamentos tbody tr').length === 0) crearFilasVacias("tablaMedicamentos");
        });

        // ====================== BOTÓN ELIMINAR (CON DIAGNÓSTICO) ======================
        document.getElementById("btnEliminar").addEventListener("click", async function () {
            const checks = document.querySelectorAll(
                "#tablaPerfumeria tbody .fila-check:checked, #tablaMedicamentos tbody .fila-check:checked"
            );

            if (checks.length === 0) return alert("Selecciona al menos una fila.");

            console.log(`[ELIMINAR] Filas seleccionadas: ${checks.length}`);

            for (const chk of checks) {
                const tr = chk.closest("tr");
                const boletaId = tr?.getAttribute("data-boleta-id");

                console.log(`[ELIMINAR] Fila analizada → data-boleta-id:`, boletaId || "(NO TIENE ID)");

                if (boletaId) {
                    console.log(`[ELIMINAR] Intentando eliminar en BD → ID: ${boletaId}`);
                    try {
                        const response = await fetch(`/Boleta/EliminarBoleta?id=${encodeURIComponent(boletaId)}`, {
                            method: "DELETE"
                        });
                        const result = await response.json();

                        console.log(`[ELIMINAR] Respuesta del backend:`, result);

                        if (result.success) {
                            console.log(`[ELIMINAR] Éxito → fila eliminada en BD y pantalla`);
                            tr.remove();
                        } else {
                            console.warn(`[ELIMINAR] Falló en BD:`, result);
                            alert("No se pudo eliminar en la base de datos.");
                        }
                    } catch (err) {
                        console.error(`[ELIMINAR] Error al intentar eliminar ID ${boletaId}:`, err);
                        alert("Error de conexión al eliminar.");
                    }
                } else {
                    console.log(`[ELIMINAR] Registro sin ID → solo se quita de la pantalla`);
                    tr.remove();
                }
            }

            if (document.querySelectorAll("#tablaPerfumeria tbody tr").length === 0) crearFilasVacias("tablaPerfumeria", 5);
            if (document.querySelectorAll("#tablaMedicamentos tbody tr").length === 0) crearFilasVacias("tablaMedicamentos", 5);

            guardarTablasEnStorage();
        });

                    // ====================== BOTÓN RESTAURAR (SIN HOVER AZUL) ======================
        document.getElementById("btnRestaurar").addEventListener("click", async function () {
            try {
                const res = await fetch(`/Boleta/GetBoletasEliminadas?idProveedor=${idProveedor}`, { credentials: 'include' });
                if (!res.ok) throw new Error(`Error HTTP ${res.status}`);
                const eliminadas = await res.json();

                if (!eliminadas.success || !eliminadas.data || eliminadas.data.length === 0) {
                    Swal.fire({
                        title: 'Sin eliminadas',
                        text: 'No hay boletas eliminadas para este proveedor.',
                        confirmButtonColor: '#007bff'
                    });
                    return;
                }

                let tablaHtml = `
                    <div style="height: 380px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 8px; background: white; font-family: system-ui, -apple-system, sans-serif;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 14px; text-align: center; table-layout: fixed;">
                            <thead style="background: #0d6efd; color: white; position: sticky; top: 0; z-index: 10; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                                <tr>
                                    <th style="padding: 10px; width: 15%; border: 1px solid #dee2e6;" translate="no">Fecha</th>
                                    <th style="padding: 10px; width: 15%; border: 1px solid #dee2e6;" translate="no">Importe F</th>
                                    <th style="padding: 10px; width: 15%; border: 1px solid #dee2e6;" translate="no">Transfer</th>
                                    <th style="padding: 10px; width: 15%; border: 1px solid #dee2e6;" translate="no">Categoría</th>
                                    <th style="padding: 10px; width: 15%; border: 1px solid #dee2e6;" translate="no">Acción</th>
                                </tr>
                            </thead>
                            <tbody style="background: #fff;">`;

                eliminadas.data.forEach(boleta => {
                    const importeLimpio = Number(boleta.importeFinal || 0).toLocaleString('es-AR');
                    const categoria = boleta.categoria || 'Sin categoría';

                    tablaHtml += `
                        <tr data-id="${boleta.idboleta}">
                            <td style="padding: 10px; border: 1px solid #dee2e6; white-space: nowrap;">${boleta.fecha || 'Sin fecha'}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6;">$ ${importeLimpio}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6;">${boleta.transfer || 'No'}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6; font-weight: ${categoria.includes('Perfumería') ? '600' : '400'}; color: ${categoria.includes('Perfumería') ? '#6f42c1' : categoria.includes('Medicamento') ? '#0d6efd' : '#6c757d'};">${categoria}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6; text-align: center;">
                                <button class="btn btn-success btn-sm restaurar-btn" data-id="${boleta.idboleta}" translate="no" style="padding: 6px 12px; font-size: 0.85rem;">
                                    <i class="bi bi-arrow-repeat"></i> Restaurar
                                </button>
                            </td>
                        </tr>`;
                });

                tablaHtml += `</tbody></table></div>`;

                Swal.fire({
                    title: '<span style="color: #007bff; font-weight: 600;">Boletas Eliminadas</span>',
                    html: tablaHtml,
                    width: '780px',
                    height: '520px',
                    heightAuto: false,
                    padding: '20px',
                    showCloseButton: true,
                    showConfirmButton: false,
                    background: '#f8f9fa',
                    didOpen: () => {
                        // Quitamos completamente el evento de hover azul
                        // (ya no agregamos mouseenter/mouseleave)

                        document.querySelectorAll('.restaurar-btn').forEach(btn => {
                            btn.addEventListener('click', async function () {
                                const boletaId = parseInt(this.getAttribute('data-id'), 10);
                                if (isNaN(boletaId)) return;

                                const confirm = await Swal.fire({
                                    title: '¿Restaurar boleta?',
                                    text: "Volverá a aparecer en el registro principal.",
                                    showCancelButton: true,
                                    confirmButtonColor: '#007bff',
                                    cancelButtonColor: '#007bff',
                                    confirmButtonText: 'Sí, restaurar',
                                    cancelButtonText: 'Cancelar'
                                });

                                if (!confirm.isConfirmed) return;

                                try {
                                    const res = await fetch('/Boleta/RestaurarBoleta', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ id: boletaId }),
                                        credentials: 'include'
                                    });
                                    const data = await res.json();
                                    if (data.success) {
                                        this.closest('tr').remove();
                                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Restaurada', showConfirmButton: false, timer: 1500 });
                                        location.reload();
                                    } else {
                                        Swal.fire('Error', data.message || 'No se pudo restaurar', 'error');
                                    }
                                } catch (err) {
                                    Swal.fire('Error', 'Error de conexión al restaurar', 'error');
                                }
                            });
                        });
                    }
                });
            } catch (err) {
                console.error('Error al cargar eliminadas:', err);
                Swal.fire({ title: 'Error', text: 'No se pudieron cargar las boletas eliminadas', icon: 'error', confirmButtonColor: '#dc3545' });
            }
        });

        // ====================== BOTÓN AGREGAR ======================
        document.getElementById("btnAgregar").addEventListener("click", function () {
            const fechaInput = document.getElementById("fecha");
            const importeInput = document.getElementById("importeFinal");
            const transferSeleccionado = document.querySelector('input[name="transfer"]:checked');
            const categoriaSeleccionada = document.querySelector('input[name="categoria"]:checked');
            const fieldsetTransfer = document.getElementById("fieldsetTransfer");
            const fieldsetCategoria = document.getElementById("fieldsetCategoria");

            if (idUsuario <= 0) return alert("❌ Error de Sesión.");

            let camposCompletos = true;
            document.querySelectorAll('.campo input').forEach(c => c.classList.remove('is-invalid'));
            fieldsetTransfer?.classList.remove('is-invalid');
            fieldsetCategoria?.classList.remove('is-invalid');

            if (!fechaInput.value.trim()) { fechaInput.classList.add('is-invalid'); camposCompletos = false; }
            if (!importeInput.value.trim()) { importeInput.classList.add('is-invalid'); camposCompletos = false; }
            if (!transferSeleccionado) { fieldsetTransfer.classList.add('is-invalid'); camposCompletos = false; }
            if (!categoriaSeleccionada) { fieldsetCategoria.classList.add('is-invalid'); camposCompletos = false; }
            if (!camposCompletos) return;

            const idTabla = categoriaSeleccionada.id === "catMedicamento" ? "tablaMedicamentos" : "tablaPerfumeria";
            const tbody = document.querySelector(`#${idTabla} tbody`);

            const fechaRaw = fechaInput.value.trim();
            const importeRaw = importeInput.value.trim();
            const fechaMostrar = formatoFechaInputAmostrar(fechaRaw);
            const transferValor = transferSeleccionado.value;
            const importeFormateado = "$ " + limpiarImporte(importeRaw).toLocaleString("es-AR");
            const categoriaValorFinal = `${nombreProveedorServer} - ${categoriaSeleccionada.value}`;

            const fila = document.createElement("tr");
            fila.innerHTML = `
                <td title="${fechaMostrar}">${fechaMostrar}</td>
                <td title="${importeFormateado}">${importeFormateado}</td>
                <td title="${transferValor}">${transferValor}</td>
                <td class="text-center"><input type="checkbox" class="fila-check"></td>
            `;
            tbody.prepend(fila);

            guardarTablasEnStorage();

            fetch("/Boleta/GuardarBoleta", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    Idusuario: idUsuario,
                    Idproveedor: idProveedor,
                    Fecha: fechaRaw,
                    ImporteFinal: limpiarImporte(importeRaw),
                    Transfer: transferValor,
                    Categoria: categoriaValorFinal,
                    Detalle: "",
                    NombreProveedor: nombreProveedorServer,
                })
            })
            .then(async response => {
                const resp = await response.json();
                if (!response.ok || !resp?.exito) {
                    alert("⚠️ Error al guardar: " + (resp?.mensaje || response.status));
                    fila.remove();
                    return;
                }
                fila.setAttribute("data-boleta-id", resp.idBoleta);
                fechaInput.value = "";
                importeInput.value = "";
                document.querySelectorAll('input[name="transfer"], input[name="categoria"]').forEach(r => r.checked = false);
            })
            .catch(err => {
                console.error(err);
                alert("❌ Error de conexión.");
                fila.remove();
            });
        });

        // ====================== CHANGE EVENT ======================
        document.addEventListener("change", function (e) {
            if (e.target.classList?.contains("fila-check")) {
                e.target.closest("tr").classList.toggle("fila-seleccionada", e.target.checked);
            }
            if (e.target.name === "transfer") document.getElementById("fieldsetTransfer")?.classList.remove('is-invalid');
            if (e.target.name === "categoria") document.getElementById("fieldsetCategoria")?.classList.remove('is-invalid');
        });

        // ====================== BOTÓN EXPORTAR ======================
        document.getElementById("btnGuardarl").addEventListener("click", async function () {
            const tablas = [
                { id: "tablaPerfumeria", hoja: "Perfumeria", titulo: "PERFUMERÍA" },
                { id: "tablaMedicamentos", hoja: "Medicamentos", titulo: "MEDICAMENTOS" }
            ];
            const workbook = new ExcelJS.Workbook();

            for (const t of tablas) {
                const ws = workbook.addWorksheet(t.hoja);
                ws.columns = [
                    { header: "Fecha", key: "fecha", width: 20 },
                    { header: "Importe", key: "importe", width: 20 },
                    { header: "Transfer", key: "transfer", width: 15 }
                ];

                ws.mergeCells("A1:C1");
                ws.getCell("A1").value = `Tabla: ${t.titulo}`;
                ws.getCell("A1").alignment = { horizontal: "center", vertical: "middle" };
                ws.getCell("A1").font = { bold: true, size: 14 };
                ws.getRow(1).height = 25;

                const headerRow = ws.addRow(["FECHA", "IMPORTE", "TRANSFER"]);
                headerRow.eachCell(cell => {
                    cell.font = { bold: true, color: { argb: "FF000000" } };
                    cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "ffc080" } };
                    cell.alignment = { horizontal: "center", vertical: "middle" };
                    cell.border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } };
                });

                const tbody = document.querySelector(`#${t.id} tbody`);
                let conteoSI = 0, conteoNO = 0;

                if (tbody) {
                    [...tbody.querySelectorAll("tr")].forEach((tr, i) => {
                        const fecha = tr.children[0]?.innerText.trim();
                        const importe = tr.children[1]?.innerText.trim();
                        const transfer = (tr.children[2]?.innerText || "").trim();
                        if (!fecha && !importe && !transfer) return;

                        if (transfer.toUpperCase() === "SÍ" || transfer.toUpperCase() === "SI") conteoSI++;
                        if (transfer.toUpperCase() === "NO") conteoNO++;

                        const row = ws.addRow([fecha, importe, transfer]);
                        const color = i % 2 === 0 ? "ddeeff" : "ccffff";
                        row.eachCell(cell => {
                            cell.alignment = { horizontal: "center", vertical: "middle" };
                            cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: color } };
                            cell.border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } };
                        });
                    });
                }

                ws.mergeCells("E2:G2");
                ws.getCell("E2").value = "Resumen Transfer";
                ws.getCell("E2").font = { bold: true, color: { argb: "FFFFFFFF" } };
                ws.getCell("E2").fill = { type: "pattern", pattern: "solid", fgColor: { argb: "33cc99" } };

                ws.mergeCells("E3:F3"); ws.getCell("E3").value = "Con Transfer (SI):"; ws.getCell("G3").value = conteoSI;
                ws.mergeCells("E4:F4"); ws.getCell("E4").value = "Sin Transfer (NO):"; ws.getCell("G4").value = conteoNO;

                ws.getColumn("E").width = 10;
                ws.getColumn("F").width = 10;
                ws.getColumn("G").width = 8;
            }

            const fecha = new Date();
            const nombreArchivo = `${nombreProveedorServer} ${fecha.getDate().toString().padStart(2,'0')}-${(fecha.getMonth()+1).toString().padStart(2,'0')}-${fecha.getFullYear()} ${fecha.getHours().toString().padStart(2,'0')}${fecha.getMinutes().toString().padStart(2,'0')}.xlsx`;

            const buffer = await workbook.xlsx.writeBuffer();
            const blob = new Blob([buffer], { type: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" });
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = nombreArchivo;
            a.click();
            URL.revokeObjectURL(url);
        });

    </script>
}