@model List<FarmaciaSantaRita.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios - Super Admin";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .btn-custom {
        background-color: #007bff;
        color: white !important;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none !important;
    }

        .btn-custom:hover {
            background-color: #0056b3;
            transform: translateY(-2px);
        }

    /* Estilo para el botón Buscar integrado (gris claro como en la imagen) */
    .btn-search-integrated {
        background-color: #f8f9fa;
        border: 1px solid #ced4da;
        border-left: none;
        color: #007bff;
        font-weight: 600;
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
        padding: 0 20px;
        transition: all 0.2s;
    }

        .btn-search-integrated:hover {
            background-color: #e9ecef;
        }

    .result-box {
        background-color: #f8f9fa;
        border-left: 5px solid #007bff;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .form-control-custom {
        border-radius: 8px 0 0 8px !important; /* Bordes izquierdos redondeados */
        border: 1px solid #ced4da;
    }
</style>

<div class="container py-5">
    <div class="result-box">

        <div class="text-center mb-4">
            <img src="~/images/file_0000000079e461fd8636559665695d53.png"
                 alt="Farmacia Santa Rita"
                 style="height: 90px; object-fit: contain;">
        </div>

        <h3 class="text-center mb-1" style="color: #007bff; font-weight: 700;">Gestión de Usuarios</h3>
        <p class="text-muted text-center small mb-4">Administra los accesos y roles del personal del sistema.</p>

        <div class="row g-2 mb-4">
            <div class="col-md-9">
                <div class="input-group">
                    <input type="text" id="userInput" class="form-control form-control-custom" placeholder="Buscar usuario..." />
                    <button class="btn btn-search-integrated" type="button">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>
            <div class="col-md-3">
                <a asp-controller="PanelSeleccion" asp-action="Index" class="btn-custom">
                    Volver
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover text-center" id="userTable">
                <thead style="background-color: #e9ecef;">
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model ?? new List<FarmaciaSantaRita.Models.Usuario>())
                    {
                        <tr>
                            <td><strong>@u.Nombre @u.Apellido</strong></td>
                            <td>@u.NombreUsuario</td>
                            <td><span class="badge bg-white text-primary border border-primary">@u.Rol</span></td>
                            <td>
                                <span style="font-weight: bold; color: @(u.Eliminado ? "#dc3545" : "#28a745")">
                                    @(u.Eliminado ? "Inactivo" : "Activo")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary cambiar-rol" data-id="@u.Idusuario">
                                        <i class="bi bi-person-gear"></i>
                                    </button>
                                    @if (!u.Eliminado)
                                    {
                                        <button class="btn btn-sm btn-outline-danger eliminar" data-id="@u.Idusuario">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success restaurar" data-id="@u.Idusuario">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Filtrado de tabla
            $("#userInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#userTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // SweetAlert para Cambiar Rol
            $('.cambiar-rol').click(function () {
                Swal.fire({
                    title: 'Modificar Rol',
                    html: `<select id="nuevoRol" class="form-select">
                             <option value="Empleado/a">Empleado/a</option>
                             <option value="Jefe/a">Jefe/a</option>
                             <option value="SuperAdmin">SuperAdmin</option>
                           </select>`,
                    confirmButtonColor: '#007bff',
                    confirmButtonText: 'Actualizar',
                    showCancelButton: true
                });
            });
        });
    </script>
}