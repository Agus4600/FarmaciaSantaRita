@model List<FarmaciaSantaRita.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios - Super Admin";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* Estilos base de la tarjeta y contenedor */
    .card-custom {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border: none;
        background-color: white;
        max-width: 900px; /* Ajustado para albergar la tabla cómodamente */
        margin: auto;
    }

    /* Botones principales (Azul sólido) */
    .btn-custom-primary {
        background-color: #007bff;
        color: white !important;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        padding: 8px 20px;
        transition: all 0.2s ease;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 38px;
    }

        .btn-custom-primary:hover {
            background-color: #0056b3;
            transform: translateY(-1px);
        }

    /* Input y Buscador integrado */
    .form-control-custom {
        border-radius: 8px 0 0 8px !important;
        border: 1px solid #ced4da;
    }

    .btn-search-integrated {
        background-color: transparent;
        border: 1px solid #ced4da;
        border-left: none;
        color: #007bff;
        font-weight: 600;
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
        padding: 0 15px;
        transition: all 0.2s;
    }

        .btn-search-integrated:hover {
            background-color: #f8f9fa;
        }

    /* Tabla Estilizada */
    .table {
        margin-top: 10px;
        font-size: 0.95rem;
    }

        .table thead {
            background-color: #f8f9fa;
        }

        .table th {
            border-bottom: 2px solid #dee2e6;
            color: #495057;
            font-weight: 600;
            text-align: center;
        }

        .table td {
            vertical-align: middle;
            text-align: center;
        }

    .status-active {
        color: #28a745;
        font-weight: bold;
    }

    .status-deleted {
        color: #dc3545;
        font-weight: bold;
    }
</style>

<div class="main-wrapper py-5">
    <div class="card card-custom p-4">

        <div class="text-center mb-4">
            <img src="~/images/file_0000000079e461fd8636559665695d53.png"
                 alt="Farmacia Santa Rita"
                 style="width: 100%; height: auto; max-height: 120px; object-fit: contain;">
        </div>

        <h4 class="text-center mb-1">Gestión de Usuarios</h4>
        <p class="text-muted text-center small mb-4">Administra los accesos y roles del personal del sistema.</p>

        <div class="d-flex align-items-center gap-2 mb-4">
            <div class="input-group flex-grow-1">
                <input type="text" id="userInput" class="form-control form-control-custom" placeholder="Buscar usuario por nombre o DNI..." />
                <button class="btn btn-search-integrated" type="button" id="btnSearch">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
            <a asp-controller="PanelSeleccion" asp-action="Index" class="btn btn-custom-primary">
                Volver
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover" id="userTable">
                <thead>
                    <tr>
                        <th>Nombre Completo</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model ?? new List<FarmaciaSantaRita.Models.Usuario>())
                    {
                        <tr>
                            <td><strong>@u.Nombre @u.Apellido</strong></td>
                            <td>@u.NombreUsuario</td>
                            <td><span class="badge bg-light text-dark border">@u.Rol</span></td>
                            <td>
                                <span class="@(u.Eliminado ? "status-deleted" : "status-active")">
                                    @(u.Eliminado ? "Inactivo" : "Activo")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-primary cambiar-rol" data-id="@u.Idusuario" title="Cambiar Rol">
                                        <i class="bi bi-person-gear"></i>
                                    </button>
                                    @if (!u.Eliminado)
                                    {
                                        <button class="btn btn-sm btn-outline-danger eliminar" data-id="@u.Idusuario" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success restaurar" data-id="@u.Idusuario" title="Restaurar">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model?.Any() ?? true)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-people mb-2 d-block" style="font-size: 2rem;"></i>
                                No se encontraron usuarios registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {

            // Lógica de filtrado simple para la tabla (simula la búsqueda)
            $("#userInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#userTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // SweetAlert para Cambiar Rol
            $('.cambiar-rol').click(function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Modificar Permisos',
                    text: 'Selecciona el nuevo rol para el usuario',
                    html: `<select id="nuevoRol" class="form-select">
                             <option value="Empleado/a">Empleado/a</option>
                             <option value="Jefe/a">Jefe/a</option>
                             <option value="SuperAdmin">SuperAdmin</option>
                           </select>`,
                    showCancelButton: true,
                    confirmButtonText: 'Actualizar',
                    cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#007bff'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const rol = document.getElementById('nuevoRol').value;
                        Swal.fire('¡Actualizado!', `El usuario ahora es ${rol}.`, 'success');
                    }
                });
            });

            // SweetAlert para Eliminar/Restaurar
            $('.eliminar, .restaurar').click(function () {
                var accion = $(this).hasClass('eliminar') ? 'Eliminar' : 'Restaurar';
                var color = accion === 'Eliminar' ? '#dc3545' : '#28a745';

                Swal.fire({
                    title: `¿Confirmas ${accion}?`,
                    text: `¿Estás seguro de que deseas ${accion.toLowerCase()} este usuario?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: color,
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, confirmar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire('Procesado', `Usuario ${accion === 'Eliminar' ? 'desactivado' : 'reactivado'} correctamente.`, 'success');
                    }
                });
            });
        });
    </script>
}