@model List<FarmaciaSantaRita.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios - Super Admin";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .btn-custom {
        background-color: #007bff;
        color: white !important;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        padding: 10px 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none !important;
    }

        .btn-custom:hover {
            background-color: #0056b3;
            transform: translateY(-2px);
        }

    .btn-search-integrated {
        background-color: #f8f9fa;
        border: 1px solid #ced4da;
        border-left: none;
        color: #007bff;
        font-weight: 600;
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
        padding: 0 20px;
        transition: all 0.2s;
    }

        .btn-search-integrated:hover {
            background-color: #e9ecef;
        }

    .result-box {
        background-color: #f8f9fa;
        border-left: 5px solid #007bff;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .form-control-custom {
        border-radius: 8px 0 0 8px !important;
        border: 1px solid #ced4da;
    }

    .table th, .table td {
        text-align: center;
        vertical-align: middle;
        padding: 12px;
    }

    .btn-sm {
        margin: 0 4px;
        font-size: 0.9rem;
    }
</style>

<div class="main-wrapper">
    <div class="card card-custom p-4">
        <div class="text-center mb-4">
            <img src="~/images/file_0000000079e461fd8636559665695d53.png"
                 alt="Farmacia Santa Rita"
                 style="width: 100%; height: auto; max-height: 180px; object-fit: contain;">
        </div>
        <h4 class="text-center mb-2">Gestión de Usuarios - Super Admin</h4>
        <p class="text-muted text-center small mb-4">Aquí puedes ver y gestionar todos los usuarios del sistema.</p>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model ?? new List<FarmaciaSantaRita.Models.Usuario>())
                    {
                        <tr>
                            <td>@u.Nombre @u.Apellido</td>
                            <td>@u.NombreUsuario</td>
                            <td>@u.Rol</td>
                            <td>@(u.Eliminado ? "Eliminado" : "Activo")</td>
                            <td>
                                <button class="btn btn-sm btn-warning cambiar-rol" data-id="@u.Idusuario" data-rol="@u.Rol">Cambiar Rol</button>
                                @if (!u.Eliminado)
                                {
                                    <button class="btn btn-sm btn-danger eliminar" data-id="@u.Idusuario">Eliminar</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success restaurar" data-id="@u.Idusuario">Restaurar</button>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model?.Any() ?? true)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No hay usuarios registrados aún.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Botón Volver (adaptado al estilo del código base) -->
        <div class="text-center mt-4">
            <a asp-controller="PanelSeleccion" asp-action="Index" class="btn btn-custom">
                <i class="bi bi-arrow-left"></i> Volver al Panel
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Toggle modal básico para cambiar rol (simulado por ahora)
            $('.cambiar-rol').click(function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Cambiar Rol',
                    html: `<select id="nuevoRol" class="form-select">
                             <option value="Empleado/a">Empleado/a</option>
                             <option value="Jefe/a">Jefe/a</option>
                             <option value="SuperAdmin">SuperAdmin</option>
                           </select>`,
                    showCancelButton: true,
                    confirmButtonText: 'Guardar',
                    cancelButtonText: 'Cancelar',
                    preConfirm: () => {
                        return document.getElementById('nuevoRol').value;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire('¡Listo!', `Rol cambiado a ${result.value} (simulado)`, 'success');
                    }
                });
            });

            // Puedes agregar lógica para eliminar/restaurar aquí cuando tengas el backend
            $('.eliminar, .restaurar').click(function () {
                var id = $(this).data('id');
                var accion = $(this).text().trim();
                Swal.fire({
                    title: `¿${accion}?`,
                    text: "Esta acción no se puede deshacer (simulado).",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Sí, ' + accion.toLowerCase()
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire('¡Hecho!', `${accion} realizado (simulado)`, 'success');
                    }
                });
            });
        });
    </script>
}