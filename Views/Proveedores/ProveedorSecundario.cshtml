@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
    <script>
        // ----------------------------------------------------
        // 1. CONSTANTES GLOBALES
        // ----------------------------------------------------
        const idProveedor = @((ViewData["IdProveedor"] ?? 0));
        const nombreProveedorServer = @Html.Raw(Json.Serialize(ViewData["NombreProveedor"] ?? "Proveedor"));
        const idUsuario = parseInt('@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")', 10);
        const CATEGORIA_FIJA = nombreProveedorServer;
        const TABLA_REGISTRO = { id: "tablaRegistro", hoja: "Registro", titulo: nombreProveedorServer };
        const STORAGE_KEY_REGISTRO = `registro_${idProveedor}`;

        function guardarRegistroEnStorage() {
            const datos = [];
            document.querySelectorAll('#tablaRegistro tbody tr').forEach(tr => {
                const celdas = tr.querySelectorAll('td');
                if (celdas.length >= 3) {
                    const fecha = celdas[0].innerText.trim();
                    const importe = celdas[1].innerText.trim();
                    const transfer = celdas[2].innerText.trim();
                    if (fecha || importe || transfer) {
                        datos.push({ fecha, importe, transfer });
                    }
                }
            });
            localStorage.setItem(STORAGE_KEY_REGISTRO, JSON.stringify(datos));
        }

        function cargarRegistroDesdeStorage() {
            const datosGuardados = localStorage.getItem(STORAGE_KEY_REGISTRO);
            if (!datosGuardados) return;
            try {
                const datos = JSON.parse(datosGuardados);
                document.querySelector('#tablaRegistro tbody').innerHTML = '';
                datos.forEach(item => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${item.fecha}</td>
                        <td>${item.importe}</td>
                        <td>${item.transfer}</td>
                        <td class="text-center"><input type="checkbox" class="fila-check"></td>
                    `;
                    document.querySelector('#tablaRegistro tbody').appendChild(tr);
                });
            } catch (e) {
                console.error("Error al cargar registro guardado:", e);
            }
        }

        // ----------------------------------------------------
        // 2. FUNCIONES DE AYUDA
        // ----------------------------------------------------
        function limpiarImporte(importe) {
            return parseInt((importe || "").toString().replace(/\./g, ""), 10) || 0;
        }

        function formatoFechaInputAmostrar(dateValue) {
            if (!dateValue) return new Date().toLocaleDateString();
            const parts = dateValue.split("-");
            return parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : dateValue;
        }

        function crearFilasVacias(idTabla, cantidad = 5) {
            const tbody = document.querySelector(`#${idTabla} tbody`);
            if (!tbody) return;
            tbody.innerHTML = "";
            for (let i = 0; i < cantidad; i++) {
                const fila = document.createElement("tr");
                fila.innerHTML = `
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="text-center"><input type="checkbox" class="fila-check"></td>
                `;
                tbody.appendChild(fila);
            }
        }

        // ----------------------------------------------------
        // 3. INICIALIZACIÓN
        // ----------------------------------------------------
        document.addEventListener("DOMContentLoaded", function () {
            const inputImporte = document.getElementById("importeFinal");
            if (inputImporte) {
                inputImporte.addEventListener("input", function () {
                    let valor = this.value.replace(/\D/g, "").substring(0, 8);
                    if (valor) valor = valor.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
                    this.value = valor;
                });
                inputImporte.addEventListener("paste", function (e) {
                    const texto = (e.clipboardData || window.clipboardData).getData("text");
                    if (!/^\d+$/.test(texto)) e.preventDefault();
                });
            }
            cargarRegistro();
            if (document.querySelectorAll('#tablaRegistro tbody tr').length === 0) {
                crearFilasVacias("tablaRegistro");
            }
        });

        // ----------------------------------------------------
        // 4. BOTÓN AGREGAR
        // ----------------------------------------------------
        document.getElementById("btnAgregar").addEventListener("click", function () {
            const fechaInput = document.getElementById("fecha");
            const importeInput = document.getElementById("importeFinal");
            const transferSeleccionado = document.querySelector('input[name="transfer"]:checked');
            const fieldsetTransfer = document.getElementById("fieldsetTransfer");

            if (idUsuario <= 0) {
                alert("❌ Error de Sesión. Por favor, recarga la página o vuelve a iniciar sesión.");
                return;
            }

            let camposCompletos = true;
            document.querySelectorAll('.campo input').forEach(c => c.classList.remove('is-invalid'));
            fieldsetTransfer?.classList.remove('is-invalid');

            if (!fechaInput.value.trim()) { fechaInput.classList.add('is-invalid'); camposCompletos = false; }
            if (!importeInput.value.trim()) { importeInput.classList.add('is-invalid'); camposCompletos = false; }
            if (!transferSeleccionado) { fieldsetTransfer.classList.add('is-invalid'); camposCompletos = false; }
            if (!camposCompletos) return;

            const tbody = document.querySelector('#tablaRegistro tbody');
            const fechaRaw = fechaInput.value.trim();
            const importeRaw = importeInput.value.trim();
            const fechaMostrar = formatoFechaInputAmostrar(fechaRaw);
            const transferValor = transferSeleccionado.value;
            const importeFormateado = `$ ${limpiarImporte(importeRaw).toLocaleString("es-AR")}`;
            const categoriaValor = CATEGORIA_FIJA;

            const fila = document.createElement("tr");
            fila.innerHTML = `
                <td title="${fechaMostrar}">${fechaMostrar}</td>
                <td title="${importeFormateado}">${importeFormateado}</td>
                <td title="${transferValor}">${transferValor}</td>
                <td class="text-center"><input type="checkbox" class="fila-check"></td>
            `;
            tbody.prepend(fila);
            guardarRegistroEnStorage();

            console.log("===== DATOS QUE SE ENVIAN A GuardarBoleta =====");
            console.log("Idusuario:", idUsuario);
            console.log("Idproveedor:", idProveedor);
            console.log("Fecha (raw):", fechaRaw);
            console.log("ImporteFinal (limpio):", limpiarImporte(importeRaw));
            console.log("Transfer:", transferValor);
            console.log("Categoria:", categoriaValor);
            console.log("Detalle:", "");

            fetch("/Boleta/GuardarBoleta", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    Idusuario: idUsuario,
                    Idproveedor: idProveedor,
                    Fecha: fechaRaw,
                    ImporteFinal: limpiarImporte(importeRaw),
                    Transfer: transferValor,
                    Categoria: categoriaValor,
                    Detalle: ""
                }),
                credentials: 'include'
            })
            .then(async response => {
                console.log("Estado HTTP:", response.status);
                const resp = await response.json();
                console.log("Respuesta del servidor:", resp);
                if (!response.ok || !resp?.exito) {
                    const mensaje = resp?.mensaje || `Error HTTP ${response.status}`;
                    console.error("Fallo en guardado:", mensaje);
                    alert("⚠️ Error al guardar: " + mensaje);
                    fila.remove();
                    return;
                }
                console.log("Guardado exitoso - ID asignado:", resp.idBoleta);
                fila.setAttribute("data-boleta-id", resp.idBoleta);
                fechaInput.value = "";
                importeInput.value = "";
                document.querySelectorAll('input[name="transfer"]').forEach(r => r.checked = false);
            })
            .catch(err => {
                console.error("Error completo en fetch:", err);
                alert("❌ Error de conexión. Revisa consola.");
                fila.remove();
            });
        });

        // ----------------------------------------------------
        // 5. BOTÓN ELIMINAR
        // ----------------------------------------------------
        document.getElementById("btnEliminar").addEventListener("click", async function () {
            const checks = document.querySelectorAll("#tablaRegistro tbody .fila-check:checked");
            if (checks.length === 0) return alert("Selecciona al menos una fila.");
            const deletePromises = [];
            for (const chk of checks) {
                const tr = chk.closest("tr");
                const boletaId = tr?.getAttribute("data-boleta-id");
                if (boletaId) {
                    const p = fetch(`/Boleta/EliminarBoleta?id=${encodeURIComponent(boletaId)}`, { method: "DELETE" })
                        .then(r => r.json())
                        .then(resp => {
                            if (resp?.success) tr.remove();
                            else alert("Error al eliminar la boleta con ID: " + boletaId);
                        })
                        .catch(err => {
                            console.error("Error en DELETE:", err);
                            alert("Error de conexión al eliminar la boleta.");
                        });
                    deletePromises.push(p);
                } else {
                    tr.remove();
                }
            }
            if (deletePromises.length) await Promise.all(deletePromises);
            const filasActuales = document.querySelectorAll("#tablaRegistro tbody tr").length;
            if (filasActuales < 5) crearFilasVacias("tablaRegistro", 5 - filasActuales);
            guardarRegistroEnStorage();
        });

        // ----------------------------------------------------
        // 7. BOTÓN GUARDAR EXCEL
        // ----------------------------------------------------
        document.getElementById("btnGuardarl").addEventListener("click", async function () {
            await generarYDescargarExcel([TABLA_REGISTRO]);
        });

        // ----------------------------------------------------
        // CARGAR REGISTRO (con logs detallados)
        // ----------------------------------------------------
        async function cargarRegistro() {
            try {
                const res = await fetch(`/Boleta/GetBoletas?idProveedor=${idProveedor}`, {
                    credentials: 'include'
                });
                if (!res.ok) throw new Error(`Error HTTP ${res.status}`);
                const data = await res.json();
                if (!data.success || !data.data) throw new Error("Respuesta inválida");
                const boletas = data.data;
                const tbody = document.querySelector('#tablaRegistro tbody');
                tbody.innerHTML = '';
                boletas.forEach(b => {
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-boleta-id', b.idboleta);
                    let importeStr = b.importeFinal;
                    if (typeof importeStr === 'number') {
                        importeStr = importeStr.toLocaleString('es-AR');
                    } else if (typeof importeStr === 'string') {
                        importeStr = importeStr.replace(/[^0-9]/g, '');
                        importeStr = Number(importeStr).toLocaleString('es-AR');
                    } else {
                        importeStr = '0';
                    }
                    const importeFinal = `$ ${importeStr}`;
                    tr.innerHTML = `
                        <td title="${b.fecha || 'Sin fecha'}">${b.fecha || 'Sin fecha'}</td>
                        <td title="${importeFinal}">${importeFinal}</td>
                        <td title="${b.transfer || 'No'}">${b.transfer || 'No'}</td>
                        <td class="text-center"><input type="checkbox" class="fila-check"></td>
                    `;
                    tbody.appendChild(tr);
                });
                if (boletas.length === 0) {
                    crearFilasVacias("tablaRegistro");
                }
                guardarRegistroEnStorage();
            } catch (err) {
                console.error("=== ERROR DETALLADO al cargar boletas desde BD ===");
                console.error("Mensaje:", err.message || "Sin mensaje");
                console.error("Nombre del error:", err.name || "Desconocido");
                console.error("Stack trace completo:", err.stack || "No disponible");
                if (err instanceof Response) {
                    err.text().then(text => {
                        console.error("Estado HTTP:", err.status);
                        console.error("Texto de error del servidor:", text || "No disponible");
                    }).catch(() => {
                        console.error("Estado HTTP:", err.status || "Desconocido");
                        console.error("No se pudo leer el cuerpo del error");
                    });
                } else {
                    console.error("URL que falló:", `/Boleta/GetBoletas?idProveedor=${idProveedor}`);
                }
                cargarRegistroDesdeStorage();
                if (document.querySelectorAll('#tablaRegistro tbody tr').length === 0) {
                    crearFilasVacias("tablaRegistro");
                }
            }
        }

        // ----------------------------------------------------
        // BOTÓN RESTAURAR
        // ----------------------------------------------------
                // ----------------------------------------------------
        // BOTÓN RESTAURAR - SWAL CON TAMAÑO FIJO (como pediste)
        // ----------------------------------------------------
        document.getElementById("btnRestaurar").addEventListener("click", async function () {
            try {
                const res = await fetch(`/Boleta/GetBoletasEliminadas?idProveedor=${idProveedor}`, {
                    credentials: 'include'
                });

                if (!res.ok) throw new Error(`Error HTTP ${res.status}`);
                const eliminadas = await res.json();

                if (!eliminadas.success || !eliminadas.data || eliminadas.data.length === 0) {
                    Swal.fire({
                        title: 'Sin eliminadas',
                        text: 'No hay boletas eliminadas para este proveedor.',
                        icon: 'info',
                        confirmButtonColor: '#007bff'
                    });
                    return;
                }

                let tablaHtml = `
                    <div style="max-height: 380px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 8px; background: white;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 14px; text-align: center;" id="tablaEliminadas">
                            <thead style="background: #0d6efd; color: white; position: sticky; top: 0; z-index: 10;">
                                <tr>
                                    <th style="padding: 10px; width: 32%;">Fecha</th>
                                    <th style="padding: 10px; width: 38%;">Importe F</th>
                                    <th style="padding: 10px; width: 20%;">Transfer</th>
                                    <th style="padding: 10px; width: 10%;">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                `;

                eliminadas.data.forEach(boleta => {
                    tablaHtml += `
                        <tr data-id="${boleta.idboleta}">
                            <td style="padding: 10px; border: 1px solid #dee2e6;">${boleta.fecha || 'Sin fecha'}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6;">$ ${boleta.importeFinal?.toLocaleString('es-AR') || '0'}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6;">${boleta.transfer || 'No'}</td>
                            <td style="padding: 10px; border: 1px solid #dee2e6; text-align: center;">
                                <button class="btn btn-success btn-sm restaurar-btn" data-id="${boleta.idboleta}">
                                    <i class="bi bi-arrow-repeat"></i> Restaurar
                                </button>
                            </td>
                        </tr>
                    `;
                });

                tablaHtml += `</tbody></table></div>`;

                Swal.fire({
                    title: 'Boletas Eliminadas',
                    html: tablaHtml,
                    width: '680px',           // ← Tamaño fijo más chico y agradable
                    heightAuto: false,        // ← Importante: evita que cambie de tamaño
                    padding: '20px',
                    showCloseButton: true,
                    showConfirmButton: false,
                    customClass: {
                        popup: 'swal-fixed-size'
                    },
                    didOpen: () => {
                        document.querySelectorAll('.restaurar-btn').forEach(btn => {
                            btn.addEventListener('click', async function () {
                                const boletaId = parseInt(this.getAttribute('data-id'), 10);
                                if (isNaN(boletaId)) return;

                                const confirm = await Swal.fire({
                                    title: '¿Restaurar boleta?',
                                    text: "Volverá a aparecer en el registro principal.",
                                    showCancelButton: true,
                                    confirmButtonColor: '#007bff',
                                    cancelButtonColor: '#6c757d',
                                    confirmButtonText: 'Sí, restaurar',
                                    cancelButtonText: 'Cancelar'
                                });

                                if (!confirm.isConfirmed) return;

                                try {
                                    const res = await fetch('/Boleta/RestaurarBoleta', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ id: boletaId }),
                                        credentials: 'include'
                                    });

                                    if (!res.ok) throw new Error("Error al restaurar");

                                    const data = await res.json();
                                    if (data.success) {
                                        this.closest('tr').remove();
                                        Swal.fire({
                                            toast: true,
                                            position: 'top-end',
                                            icon: 'success',
                                            title: 'Restaurada',
                                            showConfirmButton: false,
                                            timer: 1500
                                        });
                                        location.reload();
                                    }
                                } catch (err) {
                                    Swal.fire('Error', 'No se pudo restaurar la boleta', 'error');
                                }
                            });
                        });
                    }
                });

            } catch (err) {
                console.error('Error al cargar eliminadas:', err);
                Swal.fire({
                    title: 'Error',
                    text: 'No se pudieron cargar las boletas eliminadas',
                    icon: 'error',
                    confirmButtonColor: '#dc3545'
                });
            }
        });




        // ----------------------------------------------------
        // 9. GENERAR EXCEL
        // ----------------------------------------------------
        async function generarYDescargarExcel(tablasArray) {
            const workbook = new ExcelJS.Workbook();
            for (const t of tablasArray) {
                const ws = workbook.addWorksheet(t.hoja);
                ws.columns = [
                    { header: "Fecha", key: "fecha", width: 20 },
                    { header: "Importe", key: "importe", width: 20 },
                    { header: "Transfer", key: "transfer", width: 15 }
                ];
                ws.mergeCells("A1:C1");
                ws.getCell("A1").value = `Tabla: ${t.titulo}`;
                ws.getCell("A1").alignment = { horizontal: "center", vertical: "middle" };
                ws.getCell("A1").font = { bold: true, color: { argb: "FF000000" }, size: 14 };
                ws.getCell("A1").fill = { type: "pattern", pattern: "solid", fgColor: { argb: "f5f5dc" } };
                ws.getRow(1).height = 25;
                ["A1", "B1", "C1"].forEach(c => ws.getCell(c).border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } });

                const headerRow = ws.addRow(["FECHA", "IMPORTE", "TRANSFER"]);
                headerRow.eachCell(cell => {
                    cell.font = { bold: true, color: { argb: "FF000000" } };
                    cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "ffc080" } };
                    cell.alignment = { horizontal: "center", vertical: "middle" };
                    cell.border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } };
                });

                const tbody = document.querySelector(`#${t.id} tbody`);
                let conteoSI = 0;
                let conteoNO = 0;
                if (tbody) {
                    [...tbody.querySelectorAll("tr")].forEach((tr, i) => {
                        const fecha = tr.children[0]?.innerText.trim();
                        const importe = tr.children[1]?.innerText.trim();
                        const transfer = (tr.children[2]?.innerText || "").trim();
                        if (!fecha && !importe && !transfer) return;
                        if (transfer.toUpperCase() === "SÍ" || transfer.toUpperCase() === "SI") conteoSI++;
                        if (transfer.toUpperCase() === "NO") conteoNO++;
                        const row = ws.addRow([fecha, importe, transfer]);
                        const color = i % 2 === 0 ? "ddeeff" : "ccffff";
                        row.eachCell(cell => {
                            cell.alignment = { horizontal: "center", vertical: "middle" };
                            cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: color } };
                            cell.border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } };
                        });
                    });
                }

                ws.mergeCells("E2:G2");
                ws.getCell("E2").value = "Resumen Transfer";
                ws.getCell("E2").alignment = { horizontal: "center", vertical: "middle" };
                ws.getCell("E2").font = { bold: true, color: { argb: "FFFFFFFF" } };
                ws.getCell("E2").fill = { type: "pattern", pattern: "solid", fgColor: { argb: "33cc99" } };
                ["E2", "F2", "G2"].forEach(c => ws.getCell(c).border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } });

                ws.mergeCells("E3:F3");
                ws.getCell("E3").value = "Con Transfer (SI):";
                ws.getCell("G3").value = conteoSI;
                ws.mergeCells("E4:F4");
                ws.getCell("E4").value = "Sin Transfer (NO):";
                ws.getCell("G4").value = conteoNO;
                ["E3", "F3", "G3", "E4", "F4", "G4"].forEach(c => {
                    const cell = ws.getCell(c);
                    cell.alignment = { horizontal: "center", vertical: "middle" };
                    cell.font = { bold: true, color: { argb: "FFFFFFFF" } };
                    cell.fill = { type: "pattern", pattern: "solid", fgColor: { argb: "33cc99" } };
                    cell.border = { top: { style: "thin" }, left: { style: "thin" }, bottom: { style: "thin" }, right: { style: "thin" } };
                });

                ws.getColumn("E").width = 10;
                ws.getColumn("F").width = 10;
                ws.getColumn("G").width = 8;
            }

            const fecha = new Date();
            const dd = String(fecha.getDate()).padStart(2, "0");
            const mm = String(fecha.getMonth() + 1).padStart(2, "0");
            const yyyy = fecha.getFullYear();
            const hh = String(fecha.getHours()).padStart(2, "0");
            const min = String(fecha.getMinutes()).padStart(2, "0");
            const separadorHora = "꞉";
            const nombreArchivo = `${nombreProveedorServer} ${dd}-${mm}-${yyyy} ${hh}${separadorHora}${min}.xlsx`;

            const buffer = await workbook.xlsx.writeBuffer();
            const blob = new Blob([buffer], { type: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" });
            const url = URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = url;
            a.download = nombreArchivo;
            a.click();
            URL.revokeObjectURL(url);
        }
    </script>
}