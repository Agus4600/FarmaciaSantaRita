@model FarmaciaSantaRita.Models.Usuario
@{
    var currentIdProveedor = ViewData["IdProveedor"] ?? Context.Request.Query["idProveedor"].ToString() ?? "0";
    var currentVista = ViewData["vista"] ?? Context.Request.Query["vistaOrigen"].ToString() ?? "";
    var nombreUsuario = Model?.NombreUsuario ?? "Cuenta";
    var idProveedor = ViewData["IdProveedor"] ?? 0;
    var nombreProveedor = ViewData["NombreProveedor"] as string ?? "General";
    ViewData["Title"] = nombreUsuario;
    ViewBag.IdProveedor = ViewData["IdProveedor"];
    var vista = ViewData["vista"]?.ToString();
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* Ajustes para que el panel parezca una tarjeta redondeada y flotante */
    #offcanvasUsuarios {
        width: 850px !important;
        overflow: hidden !important;
        /* 1. Bordes redondeados en todas las esquinas */
        border-radius: 20px !important;
        /* 2. Separación del borde izquierdo y superior para que "flote" */
        margin-left: 15px;
        margin-top: 15px;
        margin-bottom: 85px; /* Espacio suficiente para no tapar el icono azul */
        /* 3. Ajuste de altura según contenido */
        height: auto !important;
        max-height: calc(100vh - 110px); /* Evita que choque con el fondo */
        /* 4. Sombra suave para dar profundidad (estética del panel Contactos) */
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
        /* 5. Quitar bordes predeterminados de Bootstrap */
        border: none !important;
    }

        /* Ajuste específico para el encabezado azul del panel */
        #offcanvasUsuarios .offcanvas-header {
            background-color: #0d6efd; /* El azul de tu botón Administrar */
            color: white;
            border-radius: 20px 20px 0 0; /* Redondea solo arriba */
            padding: 1.5rem;
        }

        #offcanvasUsuarios .offcanvas-body p {
            color: #0d6efd !important; /* El mismo azul de tus botones y encabezados */
        }

        /* Asegurar que el cuerpo tenga buen espacio interno */
        #offcanvasUsuarios .offcanvas-body {
            padding: 20px;
            overflow-y: auto;
        }


        #offcanvasUsuarios .table {
        font-size: 0.575rem; /* Letra más pequeña pero legible */
    }

        #offcanvasUsuarios .table th,
        #offcanvasUsuarios .table td {
            padding: 0.5rem 0.75rem; /* Menos padding interno */
            white-space: nowrap; /* Evita que el texto se corte en varias líneas */
            overflow: hidden;
            text-overflow: ellipsis; /* ... si el texto es muy largo */
        }
        /* 1. Centrar encabezados y celdas de la tabla */
        #offcanvasUsuarios table th,
        #offcanvasUsuarios table td {
            text-align: center;
            vertical-align: middle; /* Centrado vertical para que el select y la tilde alineen bien */
        }

        /* 2. Añadir líneas divisorias (Bordes) */
        #offcanvasUsuarios table {
            border-collapse: collapse;
        }

            #offcanvasUsuarios table th,
            #offcanvasUsuarios table td {
                border: 1px solid #dee2e6 !important; /* Líneas grises suaves */
            }

        /* 3. Estilo adicional para los encabezados */
        #offcanvasUsuarios thead th {
            background-color: #f8f9fa;
            color: #000000 !important;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.85rem;
        }

        /* 4. Efecto hover para identificar filas fácilmente */
        #offcanvasUsuarios tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }


            #offcanvasUsuarios .table th:nth-child(1),
            #offcanvasUsuarios .table td:nth-child(1) {
                width: 15%;
            }
            /* Nombre - más ancho */
            #offcanvasUsuarios .table th:nth-child(2),
            #offcanvasUsuarios .table td:nth-child(2) {
                width: 15%;
            }
            /* Usuario */
