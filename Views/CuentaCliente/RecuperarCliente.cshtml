@model List<FarmaciaSantaRita.Models.Compra>
@{
    ViewData["Title"] = "Recuperar Cliente";
}

@Html.AntiForgeryToken()
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@{
    ViewData["Title"] = "Recuperar Cliente";
}

<style>
    html, body {
        height: 100vh;
        margin: 0;
        background: #f0f2f5;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .card-principal {
        width: 90%;
        max-width: 1200px;
        height: 80vh;
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        padding: 40px;
        overflow: auto;
    }

    h1 {
        color: #0d6efd;
        text-align: center;
    }
</style>

<div class="card-principal">
    <h1>¡Prueba exitosa!</h1>
    <p style="text-align: center; font-size: 1.2rem; margin-top: 20px;">
        Si ves este mensaje, la vista carga correctamente.<br>
        El problema estaba en el código de la tabla.
    </p>

    <div style="text-align: center; margin-top: 40px;">
        <a href="@Url.Action("Index", "CuentaCliente")" class="btn btn-primary btn-lg">
            Volver a Cuentas de Clientes
        </a>
    </div>
</div>